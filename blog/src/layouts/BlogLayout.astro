---
export interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Zwischen Klassenchat, Fake News & KI — für Eltern, die ihre Kinder durch die digitale Welt begleiten.', image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {image && <meta property="og:image" content={image} />}

  <!-- RSS -->
  <link rel="alternate" type="application/rss+xml" title="Amy Surfwing Blog" href={`${base}rss.xml`} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
</head>
<body>

  <header class="site-header">
    <div class="container">
      <a href={base} class="header-brand">
        <img src={`${base}amy-256.webp`} alt="Amy Surfwing" />
        <span class="header-brand-name">Amy Surfwing</span>
        <span class="header-brand-tag">Blog</span>
      </a>
      <nav class="header-nav">
        <a href={`${base}about`} class="header-nav-link">Über uns</a>
        <a href="https://amysurfwing.de" class="header-app-link">
          App öffnen →
        </a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-inner">
        <div class="footer-brand">
          <img src={`${base}amy-256.webp`} alt="Amy Surfwing" />
          <span>Amy Surfwing</span>
        </div>
        <nav class="footer-links">
          <a href={base}>Blog</a>
          <a href={`${base}about`}>Über uns</a>
          <a href="https://www.amysurfwing.de/#/impressum">Impressum</a>
          <a href="https://amysurfwing.de">Zur App</a>
          <a href={`${base}rss.xml`}>RSS</a>
        </nav>
        <p class="footer-copy">© {new Date().getFullYear()} AYM-Vision GbR</p>
      </div>
    </div>
  </footer>

</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
